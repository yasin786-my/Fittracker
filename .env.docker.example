# ── FitTracker Docker Environment ─────────────────────────────
# Copy this file to .env.docker and edit as needed.
#   cp .env.docker.example .env.docker
# docker-compose.yml reads from this file.

# Flask
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-in-production

# Database (must match docker-compose.yml db service)
DB_USER=fittracker
DB_PASSWORD=fittracker_pass
DB_HOST=db
DB_PORT=3306
DB_NAME=fittracker_db
MYSQL_ROOT_PASSWORD=fittracker_root
DATABASE_URL=mysql://fittracker:fittracker_pass@db:3306/fittracker_db

# JWT
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000
