# --- General ---
.DS_Store
.env
.env.local
*.log
__pycache__/
.vscode/
.idea/

# --- Backend (Python/Flask) ---
backend/venv/
backend/env/
backend/ENV/
backend/.pytest_cache/
backend/*.pyc
backend/*.pyo
backend/*.db
backend/instance/

# Flask-Migrate / Alembic
