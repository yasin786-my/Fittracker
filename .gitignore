# but you exclude the pyc files inside it.
backend/migrations/__pycache__/

# --- Frontend (Node/React/Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.eslintcache

# Vite specific
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# --- Database ---
# Local MySQL dumps or SQLite files if used for testing
*.sql
*.sqlite3

# --- System & IDE ---
.python-version
.ipynb_checkpoints
.history/